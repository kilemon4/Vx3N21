-- Function to safely fetch the HWID (compatible with Potassium/common executors)
local function getClientHWID()
    local success, hwid = pcall(function()
        -- Tries standard executor HWID functions first
        if gethwid then
            return gethwid()
        elseif syn and syn.get_hwid then
            return syn.get_hwid()
        else
            -- Fallback to Roblox Client ID if no executor HWID function is found
            return game:GetService("RbxAnalyticsService"):GetClientId()
        end
    end)
    
    if success and hwid then
        return tostring(hwid)
    end
    
    return "UNKNOWN_HWID"
end

-- Function to verify user against the remote JSON
local function verifyUser()
    -- Fetch the raw JSON text from GitHub
    local success, response = pcall(function()
        return game:HttpGet(jsonUrl)
    end)

    if not success or not response then
        warn("[Auth]: Failed to connect to the key database.")
        localPlayer:Kick("Authentication Error: Could not reach the key server.")
        return false
    end

    -- Decode the JSON data
    local decodeSuccess, database = pcall(function()
        return HttpService:JSONDecode(response)
    end)

    if not decodeSuccess or type(database) ~= "table" then
        warn("[Auth]: Failed to parse JSON database.")
        localPlayer:Kick("Authentication Error: Invalid database format.")
        return false
    end

    local currentUserId = localPlayer.UserId
    local currentHWID = getClientHWID()

    print("[Auth]: Checking access for User ID:", currentUserId)

    -- Loop through the database entries to find a match
    for _, entry in ipairs(database) do
        -- Checks if HWID matches (change to `or tonumber(entry.UserId) == currentUserId` if you want user ID matching too)
        if tostring(entry.HWID) == currentHWID then
            print("[Auth]: Access Granted! Matched entry.")
            return true
        end
    end

    -- If no match is found after checking all records
    return false
end


        if descendantAddedConnection then
            descendantAddedConnection:Disconnect()
            descendantAddedConnection = nil
        end

        -- 3. Listen for FUTURE highlights being added while the toggle is active
        -- (We keep the listener active in both states so turning the toggle OFF also forces new ones to AlwaysOnTop)
        descendantAddedConnection = coreGui.DescendantAdded:Connect(function(descendant)
